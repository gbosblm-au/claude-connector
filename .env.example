# =============================================================================
# claude-connector  -  Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# For Claude Desktop: values can also be set in claude_desktop_config.json "env" block
# For Browser Claude:  values are set here or as environment variables on your cloud host
# See BROWSER-CLAUDE-SETUP.md for the browser Claude setup guide.
# =============================================================================


# -----------------------------------------------------------------------------
# HTTP SERVER (for browser-based Claude via claude.ai)
# -----------------------------------------------------------------------------

# Port for the HTTP server (default: 3000)
PORT=3000

# Host/bind address (0.0.0.0 = all interfaces, required for cloud deployments)
HOST=0.0.0.0

# API key to restrict access to the MCP endpoints.
# STRONGLY RECOMMENDED for any publicly-accessible deployment.
# Generate with: openssl rand -hex 32    OR    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=

# API key to protect the CSV upload endpoint (POST /upload/connections).
# Required if you want to push your LinkedIn CSV to a remote cloud server.
# Leave blank to disable the upload endpoint entirely.
UPLOAD_API_KEY=


# -----------------------------------------------------------------------------
# WEB SEARCH PROVIDER
# -----------------------------------------------------------------------------
# Choose "brave" (default) or "tavily"
# Brave: https://brave.com/search/api/  (free tier: 2,000 queries/month)
# Tavily: https://tavily.com            (free tier: 1,000 searches/month)
SEARCH_PROVIDER=brave


# -----------------------------------------------------------------------------
# BRAVE SEARCH API KEY
# Required when SEARCH_PROVIDER=brave OR NEWS_PROVIDER=brave
# Get your key at: https://brave.com/search/api/
# -----------------------------------------------------------------------------
BRAVE_API_KEY=your_brave_api_key_here


# -----------------------------------------------------------------------------
# TAVILY API KEY
# Required when SEARCH_PROVIDER=tavily
# Get your key at: https://app.tavily.com
# -----------------------------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here


# -----------------------------------------------------------------------------
# NEWS PROVIDER
# -----------------------------------------------------------------------------
# Choose "brave" (default, reuses BRAVE_API_KEY) or "newsapi"
# NewsAPI: https://newsapi.org  (free tier: 100 requests/day, articles up to 1 month old)
NEWS_PROVIDER=brave


# -----------------------------------------------------------------------------
# NEWS API KEY
# Required when NEWS_PROVIDER=newsapi
# Get your key at: https://newsapi.org/register
# -----------------------------------------------------------------------------
NEWS_API_KEY=your_news_api_key_here


# -----------------------------------------------------------------------------
# IMAGE SEARCH PROVIDERS
# -----------------------------------------------------------------------------
# IMAGE_PROVIDER controls which provider is used by the image_search tool.
# Options: "pexels" | "unsplash" | "both" | "auto"
# "auto" (default): uses Pexels if PEXELS_API_KEY is set, else Unsplash.
# "both": queries both providers and interleaves results.
IMAGE_PROVIDER=auto

# Pexels API Key
# Required when IMAGE_PROVIDER=pexels or IMAGE_PROVIDER=auto (with Pexels preferred)
# Get a free key at: https://www.pexels.com/api/
# On Railway: set PEXELS_API_KEY in your service Variables tab
PEXELS_API_KEY=your_pexels_api_key_here

# Unsplash Access Key
# Required when IMAGE_PROVIDER=unsplash or IMAGE_PROVIDER=auto (as fallback)
# Get a free key at: https://unsplash.com/developers
# Note: Use the "Access Key" value (not the Secret Key) here.
# On Railway: set UNSPLASH_ACCESS_KEY in your service Variables tab
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here


# -----------------------------------------------------------------------------
# WORDPRESS (optional - for publishing to WordPress)
# -----------------------------------------------------------------------------
# Set these in Railway Variables tab or here for local development.
# WP_URL:          your WordPress site URL, e.g. https://yoursite.com (no trailing slash)
# WP_USERNAME:     your WordPress login username
# WP_APP_PASSWORD: Application Password from WP Admin > Users > Profile
#
# Alternatively, use the set_wordpress_credentials MCP tool from within Claude.
WP_URL=
WP_USERNAME=
WP_APP_PASSWORD=


# -----------------------------------------------------------------------------
# LINKEDIN PATHS
# -----------------------------------------------------------------------------
# Absolute path to your LinkedIn Connections.csv export
# Default: ./data/connections.csv (relative to this project)
# LINKEDIN_CSV_PATH=/absolute/path/to/your/Connections.csv

# Absolute path to your LinkedIn profile JSON (optional)
# Default: ./data/profile.json (relative to this project)
# LINKEDIN_PROFILE_PATH=/absolute/path/to/your/profile.json


# -----------------------------------------------------------------------------
# RESULT LIMITS
# -----------------------------------------------------------------------------
DEFAULT_WEB_RESULTS=10
DEFAULT_NEWS_RESULTS=10
MAX_WEB_RESULTS=20
MAX_NEWS_RESULTS=20

# Image result limits
DEFAULT_IMAGE_RESULTS=5
MAX_IMAGE_RESULTS=20


# -----------------------------------------------------------------------------
# IMAGE DOWNLOAD (for saving images locally)
# -----------------------------------------------------------------------------
# Directory where downloaded images are stored.
# Default: ./data/images (relative to the project root)
# For Docker/Railway, consider mounting a persistent volume.
IMAGE_DOWNLOAD_DIR=


# -----------------------------------------------------------------------------
# GOOGLE DRIVE (optional — for uploading images to Google Drive)
# -----------------------------------------------------------------------------
# Choose ONE authentication method:
#
# Option A — Service Account (recommended for server deployments):
#   1. Go to Google Cloud Console > IAM & Admin > Service Accounts
#   2. Create a service account, download the JSON key file
#   3. Enable the Google Drive API for your project
#   4. Share your target Google Drive folder with the service account email
#      (the email looks like: name@project-id.iam.gserviceaccount.com)
#   5. Set the path to the JSON key file below:
#      If you bundle ./data/google-service-account.json with this project,
#      the connector will auto-load it even when this variable is left blank.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=

# Option B — OAuth2 Refresh Token (for personal Google accounts):
#   1. Go to Google Cloud Console > APIs & Services > Credentials
#   2. Create an OAuth 2.0 Client ID (Desktop app type)
#   3. Use the OAuth Playground (https://developers.google.com/oauthplayground)
#      to authorize and get a refresh token for the Drive API scope
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Default Google Drive folder ID for uploads (optional).
# Find this in the URL: https://drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=

# OAuth scopes requested when fetching an access token.
# Default: full Drive access (required for searching/reading/modifying
# files that were not created by this app itself). You may restrict to
# "https://www.googleapis.com/auth/drive.readonly" for read-only access,
# or "https://www.googleapis.com/auth/drive.file" to restrict to files
# this app created (legacy behaviour of the original connector).
# Multiple scopes can be space or comma separated.
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive

# Optional: only used with Service Account + Workspace Domain-Wide
# Delegation. Set to the email of a Workspace user to impersonate.
GOOGLE_IMPERSONATE_SUBJECT=


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Log level: "debug" | "info" | "warn" | "error"
# All logs go to stderr (for stdio server) or stdout (for HTTP server).
LOG_LEVEL=info
