# =============================================================================
# claude-connector  -  Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# For Claude Desktop: values can also be set in claude_desktop_config.json "env" block
# For Browser Claude:  values are set here or as environment variables on your cloud host
# See BROWSER-CLAUDE-SETUP.md for the browser Claude setup guide.
# =============================================================================


# -----------------------------------------------------------------------------
# HTTP SERVER (for browser-based Claude via claude.ai)
# -----------------------------------------------------------------------------

# Port for the HTTP server (default: 3000)
PORT=3000

# Host/bind address (0.0.0.0 = all interfaces, required for cloud deployments)
HOST=0.0.0.0

# API key to restrict access to the MCP endpoints.
# STRONGLY RECOMMENDED for any publicly-accessible deployment.
# Generate with: openssl rand -hex 32    OR    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=

# API key to protect the CSV upload endpoint (POST /upload/connections).
# Required if you want to push your LinkedIn CSV to a remote cloud server.
# Leave blank to disable the upload endpoint entirely.
UPLOAD_API_KEY=


# -----------------------------------------------------------------------------
# WEB SEARCH PROVIDER
# -----------------------------------------------------------------------------
# Choose "brave" (default) or "tavily"
# Brave: https://brave.com/search/api/  (free tier: 2,000 queries/month)
# Tavily: https://tavily.com            (free tier: 1,000 searches/month)
SEARCH_PROVIDER=brave


# -----------------------------------------------------------------------------
# BRAVE SEARCH API KEY
# Required when SEARCH_PROVIDER=brave OR NEWS_PROVIDER=brave
# Get your key at: https://brave.com/search/api/
# -----------------------------------------------------------------------------
BRAVE_API_KEY=your_brave_api_key_here


# -----------------------------------------------------------------------------
# TAVILY API KEY
# Required when SEARCH_PROVIDER=tavily
# Get your key at: https://app.tavily.com
# -----------------------------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here


# -----------------------------------------------------------------------------
# NEWS PROVIDER
# -----------------------------------------------------------------------------
# Choose "brave" (default, reuses BRAVE_API_KEY) or "newsapi"
# NewsAPI: https://newsapi.org  (free tier: 100 requests/day, articles up to 1 month old)
NEWS_PROVIDER=brave


# -----------------------------------------------------------------------------
# NEWS API KEY
# Required when NEWS_PROVIDER=newsapi
# Get your key at: https://newsapi.org/register
# -----------------------------------------------------------------------------
NEWS_API_KEY=your_news_api_key_here


# -----------------------------------------------------------------------------
# LINKEDIN PATHS
# -----------------------------------------------------------------------------
# Absolute path to your LinkedIn Connections.csv export
# Default: ./data/connections.csv (relative to this project)
# LINKEDIN_CSV_PATH=/absolute/path/to/your/Connections.csv

# Absolute path to your LinkedIn profile JSON (optional)
# Default: ./data/profile.json (relative to this project)
# LINKEDIN_PROFILE_PATH=/absolute/path/to/your/profile.json


# -----------------------------------------------------------------------------
# IMAGE SEARCH PROVIDERS
# -----------------------------------------------------------------------------
# IMAGE_PROVIDER controls which provider is used by the image_search tool.
# Options: "pexels" | "unsplash" | "both" | "auto"
# "auto" (default): uses Pexels if PEXELS_API_KEY is set, else Unsplash.
# "both": queries both providers and interleaves results.
IMAGE_PROVIDER=auto

# Pexels API Key
# Required when IMAGE_PROVIDER=pexels or IMAGE_PROVIDER=auto (with Pexels preferred)
# Get a free key at: https://www.pexels.com/api/
PEXELS_API_KEY=Xbe9rzAnjSWj4DeBUO8HiCGT6C2FcR3feBFEpFLOVPfF17f6g9GOYxUb

# Unsplash Access Key
# Required when IMAGE_PROVIDER=unsplash or IMAGE_PROVIDER=auto (as fallback)
# Get a free key at: https://unsplash.com/developers
# Note: Use the "Access Key" value (not the Secret Key) here.
UNSPLASH_ACCESS_KEY=15eJPl30lkQsKC-Bz_xLY61E6pZZjZNR-T7JSQrEqZ8


# -----------------------------------------------------------------------------
# RESULT LIMITS
# -----------------------------------------------------------------------------
DEFAULT_WEB_RESULTS=10
DEFAULT_NEWS_RESULTS=10
MAX_WEB_RESULTS=20
MAX_NEWS_RESULTS=20


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Log level: "debug" | "info" | "warn" | "error"
# All logs go to stderr (for stdio server) or stdout (for HTTP server).
LOG_LEVEL=info

# Image result limits
DEFAULT_IMAGE_RESULTS=5
MAX_IMAGE_RESULTS=20
