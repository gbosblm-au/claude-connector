{
  "name": "claude-connector",
  "version": "9.0.0",
  "description": "MCP server for Claude with real-time web search, news search, LinkedIn connections lookup, TrueSource outreach email send/tracking/scheduling, Google Drive/Calendar/Sheets integration, Slack/Teams messaging, inbound webhooks, WordPress publishing, image search/download, psychology assessment, plus comprehensive statistical analysis and machine learning (descriptive stats, hypothesis testing, regression, time series, clustering, PCA, KNN, anomaly detection)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:http": "node src/server-http.js",
    "dev": "node --watch src/index.js",
    "dev:http": "node --watch src/server-http.js",
    "test": "node src/test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cheerio": "^1.2.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jstat": "^1.9.6",
    "luxon": "^3.7.2",
    "ml-kmeans": "^6.0.0",
    "ml-matrix": "^6.12.0",
    "ml-pca": "^4.1.1",
    "ml-regression-multivariate-linear": "^2.0.4",
    "ml-regression-polynomial": "^3.0.0",
    "ml-regression-simple-linear": "^2.0.4",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "simple-statistics": "^7.8.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "claude",
    "anthropic",
    "linkedin",
    "web-search",
    "news",
    "ai-agent",
    "smtp",
    "email",
    "tracking",
    "scheduler",
    "google-drive",
    "google-calendar",
    "google-sheets",
    "slack",
    "teams",
    "webhook",
    "wordpress",
    "statistics",
    "machine-learning",
    "data-analysis",
    "regression",
    "time-series",
    "clustering",
    "pca"
  ],
  "license": "MIT"
}
